# Supabase is intentionally not required for static UI checks.
# Add the real values in Vercel/local env when you are ready to submit records.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
ALLOWED_ORIGIN=https://your-vercel-domain.vercel.app

# First-slice abuse seam. Vercel serverless memory is best-effort only;
# keep values conservative and replace with durable rate limiting if abuse grows.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
